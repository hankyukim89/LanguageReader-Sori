# Sori Environment Variables Configuration
# Copy this file to '.env' or '.env.local' and fill in your values

# Google Gemini API Key
VITE_GEMINI_API_KEY=AIzaSyA...

# Firebase Web App Configuration
VITE_FIREBASE_API_KEY=AIzaSyB...
VITE_FIREBASE_AUTH_DOMAIN=sori-korean-reader.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=sori-korean-reader
VITE_FIREBASE_STORAGE_BUCKET=sori-korean-reader.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Stripe Configuration (Required for Pro Upgrade checkouts)
# Use your Stripe Price ID (starts with price_...) rather than your Product ID
VITE_STRIPE_PRICE_ID=price_YOUR_STRIPE_PRICE_ID

